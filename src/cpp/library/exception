#ifndef ESBMC_EXCEPTION
#define ESBMC_EXCEPTION

// Prevent system libc++ <exception> from redefining std::exception after us.
#define _LIBCPP_EXCEPTION

// ESBMC intrinsic — no header needed.
bool nondet_bool();

namespace std
{

class exception
{
public:
  exception() noexcept
  {
  }
  virtual ~exception() noexcept
  {
  }
  virtual const char *what() const noexcept
  {
    return "std::exception";
  }
};

class bad_exception : public exception
{
public:
  bad_exception() noexcept
  {
  }
  virtual ~bad_exception() noexcept
  {
  }
  virtual const char *what() const noexcept
  {
    return "std::bad_exception";
  }
};

// Returns true if stack unwinding is in progress due to an uncaught exception.
// Modelled as nondeterministic for BMC purposes.
inline bool uncaught_exception() noexcept
{
  return nondet_bool();
}

} // namespace std

#endif // ESBMC_EXCEPTION
