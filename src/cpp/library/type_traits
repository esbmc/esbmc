struct extent<T[], 0> : integral_constant<size_t, 0>
{
};
template <class T, size_t _Ip>
struct extent<T[_Ip], 0> : integral_constant<size_t, _Ip>
{
};
template <class T, size_t _Np>
struct extent<T[], _Np> : extent<T, _Np - 1>
{
};
template <class T, size_t _Ip, size_t _Np>
struct extent<T[_Ip], _Np> : extent<T, _Np - 1>
{
};

