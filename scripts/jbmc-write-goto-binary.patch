+bool jbmc_parse_optionst::write_lowered_goto_binary(
+  const goto_modelt &goto_model)
+{
+  if(!cmdline.isset("write-goto-binary"))
+    return false;
+
+  const std::string filename = cmdline.get_value("write-goto-binary");
+  if(write_goto_binary(filename, goto_model, ui_message_handler))
+    throw system_exceptiont("failed to write goto binary " + filename);
+
+  return true;
+}
